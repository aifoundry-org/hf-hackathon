# Production / board host — copy to config.env

export ET_JOBS_PRODUCTION=1
export JOBS_BIND=127.0.0.1:8080
export JOBS_API_URL=https://jobs.your-domain.example
export JOBS_DATA_DIR=/var/lib/et-jobs

# Generate: openssl rand -hex 32
export SUBMITTER_TOKEN=REPLACE_ME_32_CHARS_MINIMUM_________
export OPERATOR_TOKEN=REPLACE_ME_32_CHARS_MINIMUM_________
export WORKER_TOKENS=board-host:REPLACE_BOARD_WORKER_TOKEN_32CH__

export HOST_ID=board-host
export SIM_ONLY_PUBLIC=0
export ET_JOBS_DRY_RUN=0

export RATE_LIMIT_SUBMIT_PER_HOUR=30
export RATE_LIMIT_READ_PER_MIN=120
export MAX_QUEUE_DEPTH=500
export MAX_RUNNING_JOBS=8
export MAX_SUBMITTER_JOBS_PER_HOUR=10

export JOBS_REPO_ROOT=/root/et-jobs-deploy
export ET_INSTALL=/opt/et
export ET_LIB_PATH=/opt/et/host:/opt/et/lib
export LAUNCHER=/opt/et/bin/erbium_soc1sim_argbuf_dynmem
export SMOKE_ELF=/opt/et/kernels/histogram.erbium-soc1sim.elf
export BOARD_LOCK=/var/lock/etsoc-shire0.lock
export SOC_RESET_SYSFS=/sys/devices/pci0000:00/0000:00:01.0/0000:01:00.0/soc_reset/reinitiate
export KERNEL_TIMEOUT=300
