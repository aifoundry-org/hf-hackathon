# Local PC — copy to config.local.env and: source deploy/config.local.env

export JOBS_BIND=127.0.0.1:18080
export JOBS_API_URL=http://127.0.0.1:18080
export JOBS_DATA_DIR="${HOME}/.local/share/et-jobs"
export JOBS_REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../../.." && pwd)"

export ET_JOBS_PRODUCTION=0
export SUBMITTER_TOKEN=local-dev-submitter-token-32chars-minimum
export OPERATOR_TOKEN=local-dev-operator-token-32chars-minimumx
export WORKER_TOKENS=local-pc:local-dev-worker-pc-token-32chars-minimum,board-host:local-dev-worker-board-token-32chars
export WORKER_TOKEN=

export HOST_ID=local-pc
export ET_JOBS_DRY_RUN=1
export KERNEL_TIMEOUT=300
export SIM_ONLY_PUBLIC=0

export RATE_LIMIT_SUBMIT_PER_HOUR=60
export RATE_LIMIT_READ_PER_MIN=300
export MAX_QUEUE_DEPTH=200
export MAX_RUNNING_JOBS=4
export MAX_SUBMITTER_JOBS_PER_HOUR=20

export LAUNCHER="${JOBS_REPO_ROOT}/.ci-work/build/erbium_soc1sim_argbuf/erbium_soc1sim_argbuf_dynmem"
export ET_INSTALL="${JOBS_REPO_ROOT}/.ci-work/et"
export ET_PLATFORM_SRC="${HOME}/et-platform"
export SMOKE_ELF="${JOBS_REPO_ROOT}/local-artifacts/kernels/histogram.erbium-soc1sim.elf"

export PYTHONPATH="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
