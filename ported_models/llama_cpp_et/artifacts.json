  "artifacts": {
    "llama_cpp_source": {
      "kind": "framework_source",
      "framework": "llama.cpp-et",
      "submodule_path": "ported_models/llama_cpp_et/src/llama.cpp-et",
      "license": "MIT",
      "license_file": "LICENSE",
      "upstream": {
        "type": "git",
        "url": "https://github.com/aifoundry-org/llama.cpp.git",
        "branch": "et",
        "revision": "13da97147c0c8c04f0df410e77c8d202cebee3fb",
        "upstream_pr": "https://github.com/aifoundry-org/llama.cpp/pull/7",
        "upstream_author": "marty1885",
        "note": "Informational only: this records where the committed submodule mirrors from. CI builds from the committed submodule_path; it does not clone from this URL. To change the framework version, bump the submodule pin in a PR (see ported_models/llama_cpp_et/src/README.md)."
      },
      "note": "Framework source comes from the committed submodule. Submitters who want a different framework version must repin the submodule as part of their PR."
    },
    "llama_cpp_build": {
      "kind": "framework_workdir",
      "framework": "llama.cpp-et",
      "env": "LLAMA_CPP_ET_WORKDIR",
      "env_aliases": ["LFM25_LLAMA_WORKDIR"],
      "local_cache": "local-artifacts/frameworks/llama.cpp-et/build-et",
      "build": {
        "cmake": "cmake",
        "configure_args": [
          "-DGGML_ET=ON",
          "-DCMAKE_BUILD_TYPE=Release",
          "-DCMAKE_CXX_STANDARD_LIBRARIES=-lglog"
        ],
        "build_args": ["--config", "Release"]
      },
      "note": "Out-of-tree CMake build of the committed llama_cpp_source submodule. Decoupled from the source path so the submodule working tree stays clean."
    },
    "llama_server": {
      "kind": "framework_binary",
      "framework": "llama.cpp-et",
      "env": "LLAMA_CPP_ET_SERVER",
      "env_aliases": ["LFM25_LLAMA_SERVER"],
      "relative_to": "llama_cpp_build",
      "relative_path": "bin/llama-server"
    },
    "llama_perplexity": {
      "kind": "framework_binary",
      "framework": "llama.cpp-et",
      "env": "LLAMA_CPP_ET_PERPLEXITY",
      "env_aliases": ["LFM25_LLAMA_PERPLEXITY"],
      "relative_to": "llama_cpp_build",
      "relative_path": "bin/llama-perplexity"
    },
